<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Frequency 2004 Social</title>
  <link rel="stylesheet" href="/css/retro.css">
  <style>
    body {
      background: linear-gradient(180deg, #F5D5DE 0%, #FFE0F0 40%, #FFF0F5 100%);
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container" style="max-width: 800px;">
    <div class="xp-window">
      <div class="xp-titlebar" style="background: linear-gradient(180deg, #ED1A7B 0%, #C43B6D 100%); border-color: #A01050;">
        <span class="xp-titlebar__title"><i class="i">&#xe54d;</i> Topic Discussion</span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn xp-titlebar__btn--close" data-close-to="/communities/<%= community.id %>">✕</button>
        </div>
      </div>
      <div class="xp-window__body" style="background: #fff;">
        
        <div class="mb-md">
          <a href="/communities/<%= community.id %>" style="color: #4A7EBB; font-weight: bold; text-decoration: none;"><i class="i">&#xea60;</i> Back to <%= community.name %> Forum</a>
        </div>

        <!-- The main Post -->
        <div class="post-item" style="border: 2px solid #ED1A7B; background: #FFF0F5; padding: 16px; border-radius: 4px;">
          <div style="display: flex; gap: 12px; align-items: flex-start;">
            <img src="<%= post.author_avatar %>" alt="" style="width: 48px; height: 48px; border-radius: 4px; border: 1px solid #ED1A7B;">
            <div>
              <h2 style="color: #ED1A7B; font-size: 18px; margin: 0 0 6px 0;"><%= post.title || 'Untitled Post' %></h2>
              <div class="post-item__meta" style="font-size: 11px; color: #666;">
                Posted by <a href="/profile/<%= post.author_username %>" style="font-weight:bold;"><%= post.author_display_name %></a> 
                on <%= new Date(post.created_at).toLocaleString() %>
              </div>
              <div class="post-item__content" style="margin-top: 12px; font-size: 14px; line-height: 1.5; color: #333; word-break: break-word; white-space: pre-line;">
                <%= post.content %>
              </div>
            </div>
          </div>
        </div>

        <!-- Replies Section -->
        <div class="xp-fieldset mt-lg">
          <legend><i class="i">&#xe54d;</i> Replies (<%= replies.length %>)</legend>
          
          <% if (replies && replies.length > 0) { %>
            <% replies.forEach((reply, index) => { %>
              <div class="reply-item" style="display: flex; gap: 10px; align-items: flex-start; background: #fcfcfc; border: 1px solid #eee; border-left: 4px solid #ED1A7B; padding: 10px; margin-bottom: 10px; border-radius: 2px;">
                <img src="<%= reply.author_avatar %>" alt="" style="width: 32px; height: 32px; border-radius: 4px;">
                <div style="flex:1;">
                  <div class="reply-item__meta" style="font-size: 11px; color: #666; display: flex; justify-content: space-between;">
                    <span>
                      #<%= index + 1 %> | <a href="/profile/<%= reply.author_username %>" style="font-weight: bold;"><%= reply.author_display_name %></a>
                    </span>
                    <span><%= new Date(reply.created_at).toLocaleString() %></span>
                  </div>
                  <div class="reply-item__content" style="margin-top: 6px; font-size: 13px; line-height: 1.4; color: #333; word-break: break-word; white-space: pre-line;">
                    <%= reply.content %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted text-small text-center" style="padding: 20px;">No replies yet. Join the conversation below!</p>
          <% } %>
        </div>

        <!-- Reply Form -->
        <% if (currentUser && isMember) { %>
          <div class="xp-fieldset mt-lg">
            <legend><i class="i">&#xe71f;</i> Add a Reply</legend>
            <form method="POST" action="/communities/<%= community.id %>/post/<%= post.id %>/reply">
              <div class="form-group mb-sm">
                <textarea name="content" class="xp-textarea w-100" rows="3" placeholder="Write your reply..." required></textarea>
              </div>
              <button type="submit" class="xp-btn xp-btn--primary">Submit Reply</button>
            </form>
          </div>
        <% } else if (currentUser && !isMember) { %>
          <div class="outset-panel text-center text-small text-muted" style="padding: 10px; border-color: #ED1A7B;">
            <i class="i">&#xe530;</i> You must join this community to write a reply.
          </div>
        <% } else { %>
          <div class="outset-panel text-center text-small text-muted" style="padding: 10px;">
            <i class="i">&#xe530;</i> Please <a href="/login">log in</a> to participate in discussions.
          </div>
        <% } %>

      </div>
    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script src="/js/app.js"></script>
</body>
</html>
