<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Yeh Un Dino Ki Baat Hai Social</title>
  <meta name="description" content="Log in to Yeh Un Dino Ki Baat Hai Social — the retro social network inspired by MySpace, Orkut, and early 2000s web culture.">
  <link rel="stylesheet" href="/css/retro.css">
</head>
<body>
  <div class="auth-container">
    <div class="xp-window auth-window">
      <div class="xp-titlebar">
        <span class="xp-titlebar__title">🔐 Login — Yeh Un Dino Ki Baat Hai Social</span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn">_</button>
          <button class="xp-titlebar__btn">□</button>
          <button class="xp-titlebar__btn xp-titlebar__btn--close">✕</button>
        </div>
      </div>
      <div class="xp-window__body">
        <!-- Retro welcome banner -->
        <div class="text-center mb-md">
          <h1 class="text-pixel" style="font-size:28px;color:#FFD700;text-shadow:2px 2px 0 #000;">
            ✿ Yeh Un Dino Ki Baat Hai ✿
          </h1>
          <p class="text-muted text-small">~*~ Those Were The Days ~*~ Social Network v2.0</p>
          <div class="retro-marquee mt-sm">
            <span class="retro-marquee__inner">
              ★ Welcome back! ★ Best viewed in Internet Explorer 6.0 at 1024x768 ★ Now with 100% more sparkles! ★
            </span>
          </div>
        </div>

        <% if (error) { %>
          <div class="auth-error">⚠️ <%= error %></div>
        <% } %>

        <form class="auth-form" method="POST" action="/login">
          <div class="form-group">
            <label for="username">👤 Username:</label>
            <input type="text" id="username" name="username" class="xp-input" required placeholder="Enter your username..." autocomplete="username">
          </div>
          <div class="form-group">
            <label for="password">🔑 Password:</label>
            <input type="password" id="password" name="password" class="xp-input" required placeholder="Enter your password..." autocomplete="current-password">
          </div>
          <button type="submit" class="xp-btn xp-btn--primary w-100">🚀 Log In</button>
        </form>

        <div class="auth-footer">
          <p>Don't have an account? <a href="/register">Register Here!</a></p>
          <p class="mt-sm text-small text-muted">
            🔒 Secure login powered by BSNL Broadband™
          </p>
        </div>

      </div>
    </div>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
