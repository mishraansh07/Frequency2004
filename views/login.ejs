<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Frequency 2004 Social</title>
  <meta name="description" content="Log in to Frequency 2004 Social — the retro social network inspired by MySpace, Orkut, and early 2000s web culture.">
  <link rel="stylesheet" href="/css/retro.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&display=swap">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@latest/font/lucide.min.css">
  <style>.i { font-family: 'lucide'; font-style: normal; font-size: 14px; vertical-align: -2px; margin-right: 3px; }</style>
</head>
<body>
  <div class="auth-container">
    <div class="xp-window auth-window">
      <div class="xp-titlebar">
        <span class="xp-titlebar__title"><i class="i">&#xe530;</i> Login — Frequency 2004 Social</span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn xp-titlebar__btn--close">✕</button>
        </div>
      </div>
      <div class="xp-window__body">
        <!-- Retro welcome banner -->
        <div class="text-center mb-md">
          <h1 class="text-pixel" style="font-size:28px;color:#FFD700;text-shadow:2px 2px 0 #000;">
            Frequency 2004
          </h1>
          <p class="text-muted text-small">~*~ Those Were The Days ~*~ Social Network v2.0</p>
          <div class="retro-marquee mt-sm">
            <span class="retro-marquee__inner">
              * Welcome back! * Best viewed in Internet Explorer 6.0 at 1024x768 * Now with 100% more sparkles! ★
            </span>
          </div>
        </div>

        <% if (error) { %>
          <div class="auth-error"><i class="i">&#xe3a3;</i> <%= error %></div>
        <% } %>

        <form class="auth-form" method="POST" action="/login">
          <div class="form-group">
            <label for="username"><i class="i">&#xea5d;</i> Username:</label>
            <input type="text" id="username" name="username" class="xp-input" required placeholder="Enter your username..." autocomplete="username">
          </div>
          <div class="form-group">
            <label for="password"><i class="i">&#xe516;</i> Password:</label>
            <input type="password" id="password" name="password" class="xp-input" required placeholder="Enter your password..." autocomplete="current-password">
          </div>
          <button type="submit" class="xp-btn xp-btn--primary w-100"><i class="i">&#xe530;</i> Log In</button>
        </form>

        <div class="auth-footer">
          <p>Don't have an account? <a href="/register">Register Here!</a></p>
          <p class="mt-sm text-small text-muted">
            <i class="i">&#xe530;</i> Secure login powered by BSNL Broadband™
          </p>
        </div>

      </div>
    </div>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
