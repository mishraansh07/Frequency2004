<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Frequency 2004 Social</title>
  <link rel="stylesheet" href="/css/retro.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container">
    <div class="xp-window">
      <div class="xp-titlebar">
        <span class="xp-titlebar__title"><i class="i">&#xea60;</i> Friend Manager</span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn xp-titlebar__btn--close">✕</button>
        </div>
      </div>
      <div class="xp-window__body">
        
        <!-- 1. PENDING REQUESTS -->
        <div class="xp-fieldset">
          <legend><i class="i">&#xe3a7;</i> Pending Friend Requests (<%= pendingRequests.length %>)</legend>
          <% if (pendingRequests && pendingRequests.length > 0) { %>
            <div class="friend-grid">
              <% pendingRequests.forEach(req => { %>
                <div class="friend-card" style="width: 140px;">
                  <img src="<%= req.avatar_url %>" alt="<%= req.display_name %>">
                  <a href="/profile/<%= req.username %>" style="font-weight:bold;"><%= req.display_name %></a>
                  <p class="text-small text-muted" style="margin-top: 4px;">Requested: <%= new Date(req.request_date).toLocaleDateString() %></p>
                  
                  <div class="d-flex gap-sm justify-between mt-sm">
                    <form method="POST" action="/friends/accept/<%= req.id %>">
                      <button type="submit" class="xp-btn xp-btn--green" style="padding: 2px 6px; font-size: 10px;"><i class="i i-sm">&#xe5cc;</i> Accept</button>
                    </form>
                    <form method="POST" action="/friends/reject/<%= req.id %>">
                      <button type="submit" class="xp-btn xp-btn--danger" style="padding: 2px 6px; font-size: 10px;"><i class="i i-sm">&#xe5cd;</i> Decline</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-small">No pending friend requests. Go explore to make new friends!</p>
          <% } %>
        </div>

        <!-- 2. MANAGE TOP 8 -->
        <div class="xp-fieldset">
          <legend><i class="i">&#xeaa0;</i> My Top 8 Friends</legend>
          <p class="text-small text-muted mb-sm">Select who appears in your profile's Top 8 grid. Leave fields blank for empty slots.</p>
          
          <form method="POST" action="/friends/top8">
            <div class="top8-grid">
              <% for (let i = 1; i <= 8; i++) { %>
                <% const slotFriend = top8.find(tf => tf.position === i); %>
                <div class="top8-card">
                  <label class="text-small" style="font-weight:bold; display:block; margin-bottom: 4px;">Slot <%= i %></label>
                  <% if (slotFriend) { %>
                    <img src="<%= slotFriend.avatar_url %>" alt="" style="width: 40px; height: 40px; border-radius: 50%;">
                  <% } else { %>
                    <div style="width: 40px; height: 40px; background: #eee; border: 1px dashed #aaa; margin: 0 auto 4px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #888;">?</div>
                  <% } %>
                  
                  <select name="friend_<%= i %>" class="xp-select w-100" style="font-size: 11px; margin-top: 4px;">
                    <option value="">-- Empty --</option>
                    <% friends.forEach(friend => { %>
                      <option value="<%= friend.id %>" <%= slotFriend && slotFriend.id === friend.id ? 'selected' : '' %>>
                        <%= friend.display_name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              <% } %>
            </div>
            <button type="submit" class="xp-btn xp-btn--primary mt-md"><i class="i">&#xe790;</i> Save Top 8</button>
          </form>
        </div>

        <!-- 3. ALL FRIENDS -->
        <div class="xp-fieldset">
          <legend><i class="i">&#xea60;</i> All Friends (<%= friends.length %>)</legend>
          <% if (friends && friends.length > 0) { %>
            <div class="friend-grid">
              <% friends.forEach(f => { %>
                <div class="friend-card" style="position: relative;">
                  <img src="<%= f.avatar_url %>" alt="<%= f.display_name %>">
                  <a href="/profile/<%= f.username %>" style="font-weight:bold;"><%= f.display_name %></a>
                  <span class="text-small text-muted" style="display:block; max-height: 1.4em; overflow:hidden;"><%= f.headline %></span>
                  
                  <form method="POST" action="/friends/remove/<%= f.id %>" style="margin-top: 6px;">
                    <button type="submit" class="xp-btn xp-btn--danger w-100" style="font-size: 10px; padding: 2px 4px;" data-confirm="Are you sure you want to remove <%= f.display_name %> from your friends?"><i class="i i-sm">&#xe725;</i> Remove</button>
                  </form>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted text-small">You don't have any friends listed yet! Search for profiles or suggest a friend request.</p>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script src="/js/app.js"></script>
</body>
</html>
