<!-- ═══════════════════════════════════════════════════════
     Retro Navbar (Orkut-inspired top navigation bar)
     ═══════════════════════════════════════════════════════ -->
<script src="/js/sounds.js"></script>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@latest/font/lucide.min.css">
<style>
  .i { font-family: 'lucide'; font-style: normal; font-size: 14px; vertical-align: -2px; margin-right: 3px; }
  .i-sm { font-size: 12px; }
  .i-lg { font-size: 16px; }
</style>
<nav class="retro-navbar">
  <a href="/home" class="retro-navbar__brand"><i class="i">&#xe9bf;</i> Frequency 2004</a>

  <div class="retro-navbar__links">
    <a href="/home"><i class="i">&#xe4b6;</i> Home</a>
    <a href="/profile/<%= currentUser ? currentUser.username : '' %>"><i class="i">&#xea5d;</i> Profile</a>
    <a href="/friends"><i class="i">&#xea60;</i> Friends</a>
    <a href="/scrapbook/<%= currentUser ? currentUser.username : '' %>"><i class="i">&#xe572;</i> Scrapbook</a>
    <a href="/communities"><i class="i">&#xea60;</i> Communities</a>
    <a href="/radio"><i class="i">&#xe618;</i> Music</a>
    <a href="/messages"><i class="i">&#xe54d;</i> DMs</a>
  </div>

  <form class="retro-navbar__search" action="/search" method="GET">
    <input type="text" name="q" placeholder="Search name or #ID..." class="xp-input">
    <button type="submit" class="xp-btn">Go!</button>
  </form>

  <div class="retro-navbar__links">
    <% if (currentUser) { %>
      <span style="color:#FFD700;font-size:11px;">Hi, <%= currentUser.display_name %>!</span>
      <a href="/logout" style="color:#FF9999;"><i class="i">&#xe530;</i> Logout</a>
    <% } else { %>
      <a href="/login"><i class="i">&#xe530;</i> Login</a>
      <a href="/register"><i class="i">&#xea5e;</i> Register</a>
    <% } %>
  </div>
</nav>
