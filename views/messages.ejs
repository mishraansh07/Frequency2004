<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DMs — Frequency 2004</title>
  <link rel="stylesheet" href="/css/retro.css">
  <style>
    body {
      background: linear-gradient(180deg, #F0F8FF 0%, #D4E6F1 100%);
    }
    .messenger-container {
      display: flex;
      gap: 15px;
      margin-top: 20px;
    }
    .friends-list-panel {
      width: 250px;
      flex-shrink: 0;
      background: #ECE9D8;
    }
    .friend-thread-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px;
      border-bottom: 1px solid #C0C0C0;
      cursor: pointer;
      text-decoration: none;
      color: #000;
    }
    .friend-thread-btn:hover {
      background: #316AC5;
      color: #fff;
    }
    .friend-thread-btn.active {
      background: #0A246A;
      color: #fff;
    }
    .friend-thread-btn:hover a, .friend-thread-btn.active a {
      color: #fff;
    }
    .friend-thread-avatar {
      width: 36px;
      height: 36px;
      border-radius: 4px;
      border: 1px solid #7F9DB9;
    }
    .chat-window-panel {
      flex: 1;
      background: #ECE9D8;
    }
    .chat-log-box {
      height: 320px;
      border: 2px inset #808080;
      background: #FFF;
      overflow-y: auto;
      padding: 10px;
      font-family: Arial, Helvetica, sans-serif;
    }
    .msg-block {
      margin-bottom: 12px;
      line-height: 1.4;
    }
    .msg-header {
      font-size: 11px;
      font-weight: bold;
    }
    .msg-header.sent {
      color: #0266B3; /* MSN Blue for current user */
    }
    .msg-header.received {
      color: #D12275; /* MSN Magenta for friend */
    }
    .msg-content {
      font-size: 13px;
      margin-left: 10px;
      word-break: break-all;
    }
    .chat-input-row {
      display: flex;
      gap: 8px;
      padding: 10px 0 0 0;
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container">
    <div class="messenger-container">
      
      <!-- ═══ LEFT SIDEBAR: CONVERSATION LIST ═══ -->
      <div class="friends-list-panel xp-window">
        <div class="xp-titlebar" style="background: linear-gradient(180deg, #7F9DB9 0%, #5E7A99 100%); border-color: #5E7A99;">
          <span class="xp-titlebar__title"><i class="i">&#xea60;</i> My Contacts</span>
        </div>
        <div class="xp-window__body" style="padding: 0; background: #fff; height: 480px; overflow-y: auto; border: 2px inset #808080;">
          <% if (chats && chats.length > 0) { %>
            <% chats.forEach(c => { %>
              <div class="friend-thread-btn <%= activeFriendId == c.friend.id ? 'active' : '' %>" 
                   onclick="selectConversation(<%= c.friend.id %>)">
                <img src="<%= c.friend.avatar_url %>" alt="" class="friend-thread-avatar">
                <div style="flex: 1; min-width: 0;">
                  <div style="font-weight: bold; font-size: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    <%= c.friend.display_name %>
                  </div>
                  <div style="font-size: 10px; opacity: 0.8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" id="snippet-<%= c.friend.id %>">
                    <% if (c.lastMessage) { %>
                      <%= c.lastMessage.sender_id === currentUser.id ? 'You: ' : '' %><%= c.lastMessage.content %>
                    <% } else { %>
                      <em>No messages yet</em>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted text-small text-center" style="padding: 20px;">You have no friends to chat with yet. <a href="/search">Find friends</a></p>
          <% } %>
        </div>
      </div>

      <!-- ═══ RIGHT PANEL: MSN CHAT DIALOG ═══ -->
      <div class="chat-window-panel xp-window">
        <div class="xp-titlebar" id="chat-titlebar">
          <span class="xp-titlebar__title" id="chat-window-header"><i class="i">&#xe54d;</i> Instant Messenger — Choose a Contact</span>
          <div class="xp-titlebar__buttons">
            <button class="xp-titlebar__btn">_</button>
            <button class="xp-titlebar__btn">□</button>
            <button class="xp-titlebar__btn xp-titlebar__btn--close" onclick="closeChat()">✕</button>
          </div>
        </div>

        <div class="xp-window__body" id="chat-empty-state" style="height: 480px; display: flex; flex-direction: column; justify-content: center; align-items: center; background: #ECE9D8;">
          <img src="/images/avatars/default.png" alt="" style="width: 80px; opacity: 0.4; filter: grayscale(1);">
          <p style="font-weight: bold; color: #555; margin-top: 12px;">Select a contact from the left list to start chatting!</p>
        </div>

        <div class="xp-window__body" id="chat-active-state" style="height: 480px; display: none; flex-direction: column; background: #ECE9D8; justify-content: space-between;">
          <!-- Toolbar -->
          <div style="background: #ece9d8; padding: 2px 6px; border-bottom: 1px solid #7f9db9; display: flex; gap: 6px; font-size: 11px; align-items: center; min-height: 24px;">
            <span style="color: #666; font-style: italic; font-size: 11px; padding-left: 4px;">Private conversation</span>
          </div>

          <!-- Chat log -->
          <div class="chat-log-box" id="chat-log">
            <!-- Populated dynamically -->
          </div>

          <!-- Form Area -->
          <div style="padding: 10px; background: #ECE9D8; border-top: 1px solid #7f9db9;">
            <div class="chat-input-row">
              <input type="text" class="xp-input" id="chat-input" placeholder="Type a message..." style="flex: 1;" onkeydown="checkSend(event)">
              <button class="xp-btn xp-btn--primary" onclick="sendMessage()" style="padding: 2px 16px;">Send</button>
            </div>
            <div style="font-size: 10px; color: #666; margin-top: 4px; display: flex; justify-content: space-between;">
              <span>Status: Connected via Broadband</span>
              <span>Encoding: UTF-8</span>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>

  <%- include('partials/taskbar') %>

  <script>
    let activeFriendId = null;
    let lastMessageId = 0;
    let pollInterval = null;
    const currentUserId = <%= currentUser.id %>;
    const currentUserName = "<%= currentUser.display_name %>";

    document.addEventListener('DOMContentLoaded', () => {
      // Check if URL specifies a friend to start chatting immediately
      const urlParams = new URLSearchParams(window.location.search);
      const friendId = urlParams.get('friendId');
      if (friendId) {
        selectConversation(parseInt(friendId));
      }
    });

    function selectConversation(friendId) {
      activeFriendId = friendId;
      lastMessageId = 0;
      
      // Update sidebar active classes
      document.querySelectorAll('.friend-thread-btn').forEach(btn => {
        btn.classList.remove('active');
      });
      event.currentTarget?.classList.add('active');

      // Swap views
      document.getElementById('chat-empty-state').style.display = 'none';
      document.getElementById('chat-active-state').style.display = 'flex';

      // Load History
      fetch(`/messages/chat/${friendId}`)
        .then(res => res.json())
        .then(data => {
          document.getElementById('chat-window-header').textContent = `<i class="i">&#xe54d;</i> Chat with ${data.friend.display_name} — [${data.friend.username}]`;
          const log = document.getElementById('chat-log');
          log.innerHTML = '';

          data.messages.forEach(msg => {
            appendMessage(msg, data.friend);
          });
          
          scrollToBottom();

          // Start Polling
          if (pollInterval) clearInterval(pollInterval);
          pollInterval = setInterval(pollNewMessages, 3000);
        })
        .catch(err => console.error('Error loading history:', err));
    }

    function appendMessage(msg, friendObj) {
      const log = document.getElementById('chat-log');
      const msgBlock = document.createElement('div');
      msgBlock.className = 'msg-block';
      msgBlock.setAttribute('data-msg-id', msg.id);

      const isMe = msg.sender_id === currentUserId;
      const senderName = isMe ? currentUserName : friendObj.display_name;
      const headerClass = isMe ? 'msg-header sent' : 'msg-header received';
      const timeStr = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

      msgBlock.innerHTML = `
        <div class="${headerClass}">${senderName} (${timeStr}) says:</div>
        <div class="msg-content">${escapeHTML(msg.content)}</div>
      `;

      log.appendChild(msgBlock);
      if (msg.id > lastMessageId) {
        lastMessageId = msg.id;
      }
    }

    function pollNewMessages() {
      if (!activeFriendId) return;

      fetch(`/messages/poll/${activeFriendId}?lastMessageId=${lastMessageId}`)
        .then(res => res.json())
        .then(data => {
          if (data.messages && data.messages.length > 0) {
            // Get active conversation friend metadata from header name
            const displayTitle = document.getElementById('chat-window-header').textContent;
            const friendName = displayTitle.replace('<i class="i">&#xe54d;</i> Chat with ', '').split(' — ')[0];
            const tempFriend = { display_name: friendName };

            data.messages.forEach(msg => {
              appendMessage(msg, tempFriend);
              
              // Run visual reaction locally if received from friend
              if (msg.sender_id !== currentUserId) {
                if (msg.content.includes('<i class="i">&#xea1c;</i> *NUKED THE CHAT!* ')) {
                  triggerNukeReaction();
                } else if (msg.content.includes('*HACKED THE CHAT!* <i class="i">&#xe5b7;</i>')) {
                  triggerHackReaction();
                } else {
                  playMSNPing();
                }
              }
            });
            scrollToBottom();

            // Update sidebar snippet
            const lastMsg = data.messages[data.messages.length - 1];
            const snippetText = (lastMsg.sender_id === currentUserId ? 'You: ' : '') + lastMsg.content;
            document.getElementById(`snippet-${activeFriendId}`).textContent = snippetText;
          }
        })
        .catch(err => console.error('Polling error:', err));
    }

    function sendMessage() {
      const input = document.getElementById('chat-input');
      const text = input.value.trim();
      if (!text || !activeFriendId) return;

      input.value = '';

      fetch('/messages/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ recipientId: activeFriendId, content: text })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          playMSNSend();
          appendMessage(data.message, { display_name: currentUserName });
          scrollToBottom();

          // Update sidebar snippet
          document.getElementById(`snippet-${activeFriendId}`).textContent = 'You: ' + text;
        }
      })
      .catch(err => console.error('Error sending:', err));
    }

    function checkSend(e) {
      if (e.key === 'Enter') {
        sendMessage();
      }
    }

    function playExplosionSound() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const bufferSize = ctx.sampleRate * 1.2;
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        const noise = ctx.createBufferSource();
        noise.buffer = buffer;

        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(800, ctx.currentTime);
        filter.frequency.exponentialRampToValueAtTime(10, ctx.currentTime + 1.0);

        const gain = ctx.createGain();
        gain.gain.setValueAtTime(1, ctx.currentTime);
        gain.gain.linearRampToValueAtTime(0.01, ctx.currentTime + 1.0);

        noise.connect(filter);
        filter.connect(gain);
        gain.connect(ctx.destination);

        noise.start();
      } catch (err) {
        console.error('AudioContext error:', err);
      }
    }

    function playDialUpSound() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc1 = ctx.createOscillator();
        const osc2 = ctx.createOscillator();
        const gain = ctx.createGain();
        
        osc1.type = 'sawtooth';
        osc1.frequency.setValueAtTime(800, ctx.currentTime);
        osc1.frequency.linearRampToValueAtTime(1800, ctx.currentTime + 0.3);
        osc1.frequency.setValueAtTime(1200, ctx.currentTime + 0.3);
        osc1.frequency.exponentialRampToValueAtTime(100, ctx.currentTime + 1.2);
        
        osc2.type = 'square';
        osc2.frequency.setValueAtTime(1200, ctx.currentTime);
        osc2.frequency.linearRampToValueAtTime(600, ctx.currentTime + 0.5);
        osc2.frequency.setValueAtTime(2000, ctx.currentTime + 0.5);
        osc2.frequency.linearRampToValueAtTime(150, ctx.currentTime + 1.2);
        
        gain.gain.setValueAtTime(0.15, ctx.currentTime);
        gain.gain.linearRampToValueAtTime(0.01, ctx.currentTime + 1.2);
        
        osc1.connect(gain);
        osc2.connect(gain);
        gain.connect(ctx.destination);
        
        osc1.start();
        osc2.start();
        setTimeout(() => {
          osc1.stop();
          osc2.stop();
        }, 1200);
      } catch (err) {
        console.error('AudioContext error:', err);
      }
    }

    function triggerNukeReaction() {
      const chatWindow = document.getElementById('chat-active-state');
      const chatLog = document.getElementById('chat-log');
      
      playExplosionSound();

      // Violent shake effect
      let offset = 20;
      let count = 0;
      const shakeInterval = setInterval(() => {
        const dx = (Math.random() - 0.5) * offset;
        const dy = (Math.random() - 0.5) * offset;
        chatWindow.style.transform = `translate(${dx}px, ${dy}px)`;
        count++;
        if (count > 25) {
          clearInterval(shakeInterval);
          chatWindow.style.transform = '';
        }
      }, 40);

      // Flashing background color effect
      let flashCount = 0;
      const colors = ['#ff3333', '#ff9933', '#ffff33', '#ffffff'];
      const flashInterval = setInterval(() => {
        chatLog.style.background = colors[flashCount % colors.length];
        flashCount++;
        if (flashCount > 12) {
          clearInterval(flashInterval);
          chatLog.style.background = '#ffffff';
        }
      }, 80);

      // Spawn floating explosion emojis
      for (let i = 0; i < 20; i++) {
        setTimeout(() => {
          const emoji = document.createElement('div');
          emoji.textContent = ['', '', '', '💨'][Math.floor(Math.random() * 4)];
          const rect = chatLog.getBoundingClientRect();
          const x = rect.left + Math.random() * (rect.width - 40);
          const y = rect.top + Math.random() * (rect.height - 40);
          emoji.style.cssText = `
            position: fixed; left: ${x}px; top: ${y}px;
            pointer-events: none; z-index: 9999;
            font-size: ${24 + Math.random() * 24}px;
            animation: explode-fade 0.8s ease-out forwards;
          `;
          document.body.appendChild(emoji);
          setTimeout(() => emoji.remove(), 800);
        }, i * 30);
      }

      // Add explosion animation styles dynamically if missing
      if (!document.getElementById('nuke-style')) {
        const style = document.createElement('style');
        style.id = 'nuke-style';
        style.textContent = `
          @keyframes explode-fade {
            0% { opacity: 1; transform: scale(0.5) rotate(0deg); }
            50% { transform: scale(1.5) rotate(180deg); }
            100% { opacity: 0; transform: scale(2) rotate(360deg); }
          }
        `;
        document.head.appendChild(style);
      }
    }

    function triggerHackReaction() {
      playDialUpSound();
      const chatLog = document.getElementById('chat-log');
      const originalHTML = chatLog.innerHTML;
      chatLog.style.background = '#000000';
      chatLog.style.color = '#00ff00';
      chatLog.style.fontFamily = "'Courier New', monospace";
      
      let count = 0;
      const scrambleInterval = setInterval(() => {
        chatLog.innerText = Array.from({length: 400}, () => Math.random() > 0.5 ? '0' : '1').join(' ');
        count++;
        if (count > 15) {
          clearInterval(scrambleInterval);
          chatLog.innerHTML = originalHTML;
          chatLog.style.background = '#ffffff';
          chatLog.style.color = '';
          chatLog.style.fontFamily = '';
          scrollToBottom();
        }
      }, 100);
    }

    function sendNuke() {
      if (!activeFriendId) return;
      triggerNukeReaction();

      fetch('/messages/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ recipientId: activeFriendId, content: '<i class="i">&#xea1c;</i> *NUKED THE CHAT!* ' })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          appendMessage(data.message, { display_name: currentUserName });
          scrollToBottom();
          document.getElementById(`snippet-${activeFriendId}`).textContent = 'You: <i class="i">&#xea1c;</i> *NUKED THE CHAT!* ';
        }
      })
      .catch(err => console.error('Error sending nuke:', err));
    }

    function sendHack() {
      if (!activeFriendId) return;
      triggerHackReaction();

      fetch('/messages/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ recipientId: activeFriendId, content: '*HACKED THE CHAT!* <i class="i">&#xe5b7;</i>' })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          appendMessage(data.message, { display_name: currentUserName });
          scrollToBottom();
          document.getElementById(`snippet-${activeFriendId}`).textContent = 'You: *HACKED THE CHAT!* <i class="i">&#xe5b7;</i>';
        }
      })
      .catch(err => console.error('Error sending hack:', err));
    }

    function closeChat() {
      if (pollInterval) clearInterval(pollInterval);
      activeFriendId = null;
      document.getElementById('chat-active-state').style.display = 'none';
      document.getElementById('chat-empty-state').style.display = 'flex';
      document.getElementById('chat-window-header').textContent = '<i class="i">&#xe54d;</i> Instant Messenger — Choose a Contact';
    }

    function scrollToBottom() {
      const log = document.getElementById('chat-log');
      log.scrollTop = log.scrollHeight;
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          "'": '&#39;',
          '"': '&quot;'
        }[tag] || tag)
      );
    }
  </script>
</body>
</html>
