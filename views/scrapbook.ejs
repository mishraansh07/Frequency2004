<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Frequency 2004 Social</title>
  <link rel="stylesheet" href="/css/retro.css">
  <style>
    body {
      background: linear-gradient(180deg, #F5D5DE 0%, #FFE0F0 40%, #FFF0F5 100%);
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container" style="max-width: 800px;">
    <div class="xp-window">
      <div class="xp-titlebar" style="background: linear-gradient(180deg, #ED1A7B 0%, #C43B6D 100%); border-color: #A01050;">
        <span class="xp-titlebar__title"><i class="i">&#xe572;</i> <%= profileUser.display_name %>'s Scrapbook</span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn">_</button>
          <button class="xp-titlebar__btn">□</button>
          <button class="xp-titlebar__btn xp-titlebar__btn--close">✕</button>
        </div>
      </div>
      <div class="xp-window__body" style="background: #fff;">
        
        <div class="mb-md">
          <a href="/profile/<%= profileUser.username %>" style="color: #4A7EBB; font-weight: bold; text-decoration: none;">← Back to <%= profileUser.display_name %>'s Profile</a>
        </div>

        <!-- Add Scrap Form -->
        <% if (currentUser) { %>
          <div class="xp-fieldset">
            <legend><i class="i">&#xe71f;</i> Leave a Scrap (Message)</legend>
            <form method="POST" action="/scrapbook/<%= profileUser.username %>">
              <div class="form-group mb-sm">
                <textarea name="content" class="xp-textarea w-100" rows="3" placeholder="Write a scrap..." required></textarea>
              </div>
              <button type="submit" class="xp-btn xp-btn--primary">Send Scrap 💌</button>
            </form>
          </div>
        <% } else { %>
          <div class="outset-panel text-center text-small text-muted" style="padding: 10px;">
            <i class="i">&#xe530;</i> Please <a href="/login">log in</a> to leave a scrap.
          </div>
        <% } %>

        <!-- Scraps Feed -->
        <div class="xp-fieldset mt-lg">
          <legend><i class="i">&#xe572;</i> Scraps</legend>
          <% if (scraps && scraps.length > 0) { %>
            <% scraps.forEach(scrap => { %>
              <div class="scrap-item" style="border: 1px solid #f0ccd7; background: #fff; padding: 12px; margin-bottom: 12px; border-radius: 4px; display: flex; gap: 12px;">
                <img src="<%= scrap.author_avatar %>" alt="" class="scrap-item__avatar" style="width: 50px; height: 50px; border-radius: 4px; border: 1px solid #f0ccd7;">
                <div class="scrap-item__body" style="flex:1;">
                  <div class="d-flex justify-between align-center" style="font-size: 11px; color: #666;">
                    <span>
                      From <a href="/profile/<%= scrap.author_username %>" style="font-weight: bold; color: #ED1A7B;"><%= scrap.author_display_name %></a>
                    </span>
                    <span>
                      <%= new Date(scrap.created_at).toLocaleString() %>
                      <% if (currentUser && (scrap.author_id === currentUser.id || profileUser.id === currentUser.id)) { %>
                        <!-- If owner of profile or author of scrap, they can delete it -->
                        <!-- Wait! The route checks if author_id = currentUser.id, let's see -->
                        <% if (scrap.author_id === currentUser.id) { %>
                          <form method="POST" action="/scrapbook/delete/<%= scrap.id %>" style="display:inline; margin-left: 8px;">
                            <button type="submit" class="xp-btn xp-btn--danger" style="font-size: 9px; padding: 1px 4px;" data-confirm="Are you sure you want to delete this scrap?">Delete</button>
                          </form>
                        <% } %>
                      <% } %>
                    </span>
                  </div>
                  <div class="scrap-item__content" style="margin-top: 8px; font-size: 13px; color: #333; line-height: 1.4; word-break: break-word; white-space: pre-line;">
                    <%= scrap.content %>
                  </div>
                </div>
              </div>
            <% }) %>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
              <div class="pagination">
                <% if (page > 1) { %>
                  <a href="/scrapbook/<%= profileUser.username %>?page=<%= page - 1 %>">« Prev</a>
                <% } %>
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <% if (i === page) { %>
                    <span class="current"><%= i %></span>
                  <% } else { %>
                    <a href="/scrapbook/<%= profileUser.username %>?page=<%= i %>"><%= i %></a>
                  <% } %>
                <% } %>
                <% if (page < totalPages) { %>
                  <a href="/scrapbook/<%= profileUser.username %>?page=<%= page + 1 %>">Next »</a>
                <% } %>
              </div>
            <% } %>

          <% } else { %>
            <p class="text-muted text-small text-center" style="padding: 30px;">No scraps yet! Go ahead and say hello! 😊</p>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script src="/js/app.js"></script>
</body>
</html>
