<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= locals.title || 'Retro Music Player' %> — Frequency 2004</title>
  <link rel="stylesheet" href="/css/retro.css">
  <link rel="stylesheet" href="/css/radio.css">
</head>
<body>
  <audio id="radio-audio" preload="none"></audio>
  <%- include('partials/navbar') %>

  <div class="page-container">
    <div class="app-container" style="display:flex; justify-content:center; gap:20px; flex-wrap:wrap; margin-top:20px;">
      
      <!-- ========================================================
           LEFT PANEL: RETRO FM RADIO (Skeuomorphic)
           ======================================================== -->
      <div style="display:flex; flex-direction:column; gap:20px; align-items:center; width:300px; max-width:100%;">
        <!-- iPod Body -->
        <div class="ipod-body" id="radio-window" style="margin:0;">
          
          <!-- iPod Screen -->
          <div class="ipod-screen-container">
            <div class="ipod-screen">
              <!-- Status Bar -->
              <div class="ipod-statusbar">
                <span id="ipod-status-title">iPod</span>
                <span class="ipod-battery"></span>
              </div>

              <!-- Menu View -->
              <div class="ipod-menu" id="ipod-menu">
                <!-- JS will populate menu items here -->
              </div>

              <!-- Now Playing View -->
              <div class="ipod-now-playing" id="ipod-now-playing" style="display:none;">
                <div class="ipod-np-title" id="ipod-np-title">Now Playing</div>
                <div class="ipod-np-artist" id="ipod-np-artist">Loading...</div>
                
                <div class="ipod-np-progress">
                  <div class="ipod-np-bar">
                    <div class="ipod-np-fill" id="ipod-np-fill"></div>
                  </div>
                </div>
                <div class="ipod-np-time" style="display:flex; justify-content:space-between; font-size:10px; color:#555; margin-top:3px; font-family:'Courier New', monospace; padding: 0 2px;">
                  <span id="ipod-np-elapsed">0:00</span>
                  <span id="ipod-np-duration">0:00</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Click Wheel -->
          <div class="ipod-wheel-container">
            <div class="ipod-wheel">
              <button class="ipod-wheel-btn ipod-btn-menu" id="btn-ipod-menu" onclick="ipodMenu()">MENU</button>
              <button class="ipod-wheel-btn ipod-btn-prev" id="btn-ipod-prev" onclick="ipodPrev()">|&lt;&lt;</button>
              <button class="ipod-wheel-btn ipod-btn-next" id="btn-ipod-next" onclick="ipodNext()">&gt;&gt;|</button>
              <button class="ipod-wheel-btn ipod-btn-play" id="btn-ipod-play" onclick="ipodPlayPause()">&gt;||</button>
              
              <div class="ipod-center-btn" id="btn-ipod-center" onclick="ipodSelect()"></div>
            </div>
          </div>
          
        </div>

        <!-- Listening Party Manager Panel -->
        <div class="xp-window" style="width:100%; box-sizing:border-box;">
          <div class="xp-titlebar">
            <span class="xp-titlebar__title"><i class="i">&#xea07;</i> Music Party Room</span>
          </div>
          <div class="xp-window__body text-small" style="padding:10px; background:#ece9d8;">
            <% if (locals.currentUser) { %>
              <div id="party-controls">
                <div id="no-party-state">
                  <p style="margin:0 0 8px 0; color:#555; line-height:1.3;">Start a synchronized music listening room and invite your friends to listen with you in real-time!</p>
                  <button class="xp-btn xp-btn--primary w-100" onclick="startParty()"><i class="i">&#xea07;</i> Start listening party</button>
                </div>
                
                <div id="party-active-state" style="display:none;">
                  <p style="margin:0 0 6px 0;"><strong>Status:</strong> <span id="party-role-badge" style="background:#0a246a; color:#fff; padding:1px 6px; border-radius:3px; font-size:10px;">Host</span></p>
                  <p style="margin:0 0 8px 0; color:#333;">Room ID: <strong id="party-room-id">None</strong></p>
                  
                  <div id="host-invite-section" style="display:none; border-top:1px groove #fff; padding-top:8px; margin-top:8px;">
                    <label style="font-weight:bold; display:block; margin-bottom:6px;">Invite Friends to Party:</label>
                    <div id="invite-friends-list" style="max-height: 100px; overflow-y: auto; background: #fff; border: 1px inset #808080; padding: 4px; margin-bottom: 8px;">
                      <% if (locals.friends && friends.length > 0) { %>
                        <% friends.forEach(f => { %>
                          <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
                            <input type="checkbox" name="invite-friend-check" value="<%= f.id %>" id="chk-friend-<%= f.id %>" style="margin:0;">
                            <label for="chk-friend-<%= f.id %>" style="cursor: pointer; font-size:11px; color:#000;"><%= f.display_name %></label>
                          </div>
                        <% }) %>
                      <% } else { %>
                        <div style="color: #777; font-size:10px; font-style:italic; padding: 4px;">No contacts to invite</div>
                      <% } %>
                    </div>
                    <button class="xp-btn xp-btn--green w-100" onclick="sendMultipleInvites()">Invite Selected Friends</button>
                    <div id="invite-status" style="color:green; font-size:11px; margin-top:4px; font-weight:bold; display:none;">Invite sent! ✉</div>
                  </div>

                  <div id="guest-status-section" style="display:none; color:#555; font-style:italic; line-height:1.3;">
                    Synchronized with the host. Music playback is managed by the room owner.
                  </div>

                  <button class="xp-btn xp-btn--danger w-100 mt-md" onclick="leaveParty()">Leave Room</button>
                </div>
              </div>
            <% } else { %>
              <p style="margin:0; text-align:center; color:#555;"><a href="/login">Log in</a> to start or join a listening party!</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ========================================================
           RIGHT PANEL: RETRO SHOUTBOX
           ======================================================== -->
      <div class="shoutbox-panel xp-window" id="shoutbox-window" style="width:480px; max-width:100%; min-width:300px; box-sizing:border-box; display:flex; flex-direction:column;">
        <!-- XP Titlebar -->
        <div class="xp-titlebar">
          <span class="xp-titlebar__title">
            <i class="i">&#xe54d;</i> Retro Shoutbox — Online Chat
          </span>
          <div class="xp-titlebar__buttons">
            <button class="xp-titlebar__btn xp-titlebar__btn--close" data-close-to="/home">✕</button>
          </div>
        </div>

        <!-- Shoutbox Body -->
        <div class="shoutbox-body xp-window__body" style="padding:0; background:#ece9d8; display:flex; flex-direction:column; flex:1; min-height:450px;">
          <!-- Toolbar -->
          <div class="shoutbox-toolbar" style="background:#ece9d8; padding:3px 8px; border-bottom:1px solid #7f9db9; min-height:22px; display:flex; align-items:center;">
            <span style="font-size:11px; color:#555; font-style:italic;">Shoutbox Chatroom</span>
          </div>

          <!-- Messages container -->
          <div class="shoutbox shoutbox-messages" id="shoutbox-messages" style="flex:1; margin:6px; border:2px inset #808080; background:#fff; color:#000; font-family:var(--font-system); font-size:13px; padding:0; overflow-y:auto; overflow-x:hidden;">
            <!-- Messages populated by JS -->
          </div>

          <!-- Input Area -->
          <div class="shoutbox-input-area" style="padding:10px; background:#ece9d8; border-top:1px solid #7f9db9; display:flex; gap:6px;">
            <% if (currentUser) { %>
              <input type="text" class="shoutbox-input xp-input" id="shoutbox-input"
                     placeholder="Type a message and press Enter..."
                     maxlength="200" style="flex:1;">
              <button class="shoutbox-send-btn xp-btn xp-btn--primary" onclick="sendShoutboxMessage()">Send</button>
            <% } else { %>
              <input type="text" class="shoutbox-input xp-input" disabled
                     placeholder="<i class="i">&#xe530;</i> Please log in to shout!" style="flex:1; background:#eee;">
              <a href="/login" class="xp-btn xp-btn--primary" style="text-decoration:none; text-align:center; padding-top:3px;">Log In</a>
            <% } %>
          </div>

          <!-- Status Bar -->
          <div class="shoutbox-statusbar" style="background:#d4d0c8; font-size:11px; padding:4px 8px; border-top:1px solid #808080; display:flex; justify-content:space-between; color:#444;">
            <div style="display:flex; align-items:center; gap:6px;">
              <span style="display:inline-block; width:8px; height:8px; background:limegreen; border-radius:50%;"></span>
              <span>Live FM Chat</span>
            </div>
            <span>Lag: 56ms | Dial-up 56k</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script>
    const currentUserName = "<%= locals.currentUser ? currentUser.username : '' %>";
    const currentUserDisplayName = "<%= locals.currentUser ? currentUser.display_name : '' %>";
    const currentUserAvatar = "<%= locals.currentUser ? currentUser.avatar_url : '/images/avatars/default.png' %>";
  </script>
  <script src="/js/app.js"></script>
  <script src="/js/radio.js"></script>
</body>
</html>
