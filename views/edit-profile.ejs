<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile — Frequency 2004</title>
  <link rel="stylesheet" href="/css/retro.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container">
    <div class="xp-window">
      <div class="xp-titlebar">
        <span class="xp-titlebar__title"><i class="i">&#xe71f;</i> Edit Profile — <%= user.username %></span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn">_</button>
          <button class="xp-titlebar__btn">□</button>
          <button class="xp-titlebar__btn xp-titlebar__btn--close">✕</button>
        </div>
      </div>
      <div class="xp-window__body">
        <form method="POST" action="/profile/<%= user.username %>/edit">
          <!-- Basic Info -->
          <div class="xp-fieldset">
            <legend><i class="i">&#xeaa0;</i> Basic Info</legend>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Display Name:</label>
              <input type="text" name="display_name" class="xp-input w-100" value="<%= user.display_name %>" maxlength="50">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;display:block;margin-bottom:6px;">Choose Retro Pixel Avatar:</label>
              <div class="d-flex gap-md" style="flex-wrap:wrap; background:#f5f5f5; padding:10px; border:2px inset #999; border-radius:4px;">
                <% 
                  const presets = [
                    { path: '/images/avatars/default.png', label: 'Default' },
                    { path: '/images/avatars/pixel_boy_blue_1783831781477.png', label: 'Pixel Boy' },
                    { path: '/images/avatars/pixel_girl_pink_1783831809448.png', label: 'Pixel Girl' },
                    { path: '/images/avatars/cyber_cat_1783831823440.png', label: 'Cool Cat' },
                    { path: '/images/avatars/crt_monitor_1783831864729.png', label: 'Retro PC' },
                    { path: '/images/avatars/avatar_alien_1783823525098.png', label: 'Invader' },
                    { path: '/images/avatars/avatar_puppy_1783823536377.png', label: 'Puppy' },
                    { path: '/images/avatars/avatar_boombox_1783823552230.png', label: 'Boombox' },
                    { path: '/images/avatars/retro_gameboy_1783831852295.png', label: 'Gameboy' }
                  ];
                  presets.forEach(p => { 
                %>
                  <label style="display:flex; flex-direction:column; align-items:center; cursor:pointer; gap:4px; font-size:11px;">
                    <img src="<%= p.path %>" alt="" style="width:50px; height:50px; border:2px outset #ccc; padding:2px; background:#fff; <%= user.avatar_url === p.path ? 'border-color:var(--xp-blue); box-shadow:0 0 4px var(--xp-blue);' : '' %>">
                    <span style="font-weight:<%= user.avatar_url === p.path ? 'bold' : 'normal' %>;"><%= p.label %></span>
                    <input type="radio" name="avatar_url" value="<%= p.path %>" <%= user.avatar_url === p.path ? 'checked' : '' %> style="margin-top:2px;">
                  </label>
                <% }) %>
              </div>
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Headline / Tagline:</label>
              <input type="text" name="headline" class="xp-input w-100" value="<%= user.headline %>" placeholder="~*~ Your cool tagline ~*~">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Mood:</label>
              <input type="text" name="mood" class="xp-input w-100" value="<%= user.mood %>" placeholder="Happy">
            </div>
            <div class="d-flex gap-md">
              <div class="form-group mb-sm" style="flex:1">
                <label style="font-size:12px;font-weight:bold;">Location:</label>
                <input type="text" name="location" class="xp-input w-100" value="<%= user.location %>">
              </div>
              <div class="form-group mb-sm" style="flex:1">
                <label style="font-size:12px;font-weight:bold;">Gender:</label>
                <select name="gender" class="xp-select w-100">
                  <option value="" <%= !user.gender ? 'selected' : '' %>>Select...</option>
                  <option value="Male" <%= user.gender === 'Male' ? 'selected' : '' %>>Male</option>
                  <option value="Female" <%= user.gender === 'Female' ? 'selected' : '' %>>Female</option>
                  <option value="Other" <%= user.gender === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>
              <div class="form-group mb-sm" style="width:80px">
                <label style="font-size:12px;font-weight:bold;">Age:</label>
                <input type="number" name="age" class="xp-input w-100" value="<%= user.age || '' %>" min="13" max="120">
              </div>
            </div>
          </div>

          <!-- About Me -->
          <div class="xp-fieldset">
            <legend><i class="i">&#xe71f;</i> About Me</legend>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Bio:</label>
              <textarea name="bio" class="xp-textarea w-100" rows="4" placeholder="Tell the world about yourself..."><%= user.bio %></textarea>
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Who I'd Like to Meet:</label>
              <textarea name="who_id_like_to_meet" class="xp-textarea w-100" rows="2"><%= user.who_id_like_to_meet %></textarea>
            </div>
          </div>

          <!-- Interests (MySpace-style) -->
          <div class="xp-fieldset">
            <legend><i class="i">&#xeb16;</i> Interests</legend>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">General:</label>
              <input type="text" name="interests_general" class="xp-input w-100" value="<%= user.interests_general %>">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Music:</label>
              <input type="text" name="interests_music" class="xp-input w-100" value="<%= user.interests_music %>" placeholder="Bollywood, Rock, Pop...">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Movies:</label>
              <input type="text" name="interests_movies" class="xp-input w-100" value="<%= user.interests_movies %>">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Television:</label>
              <input type="text" name="interests_tv" class="xp-input w-100" value="<%= user.interests_tv %>">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Books:</label>
              <input type="text" name="interests_books" class="xp-input w-100" value="<%= user.interests_books %>">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Heroes:</label>
              <input type="text" name="interests_heroes" class="xp-input w-100" value="<%= user.interests_heroes %>">
            </div>
          </div>

          <!-- Customization (MySpace custom CSS!) -->
          <div class="xp-fieldset">
            <legend>Profile Customization</legend>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Profile Song URL (YouTube/SoundCloud):</label>
              <input type="text" name="profile_song" class="xp-input w-100" value="<%= user.profile_song %>" placeholder="https://...">
            </div>
            <div class="form-group mb-sm">
              <label style="font-size:12px;font-weight:bold;">Custom CSS (MySpace-style!):</label>
              <textarea name="custom_css" class="xp-textarea w-100" rows="4" style="font-family:'Courier New',monospace;font-size:12px;" placeholder="body { background: #000 !important; } .profile-content { color: #0f0 !important; }"><%= user.custom_css %></textarea>
              <p class="text-small text-muted mt-sm"><i class="i">&#xe3a3;</i> Use at your own risk! Just like the real MySpace. </p>
            </div>
          </div>

          <div class="d-flex gap-md justify-between">
            <button type="submit" class="xp-btn xp-btn--primary"><i class="i">&#xe790;</i> Save Changes</button>
            <a href="/profile/<%= user.username %>" class="xp-btn" style="text-decoration:none;">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script src="/js/app.js"></script>
</body>
</html>
