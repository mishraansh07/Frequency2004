<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= community.name %> — Frequency 2004 Social</title>
  <link rel="stylesheet" href="/css/retro.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="page-container">
    <div class="xp-window">
      <div class="xp-titlebar">
        <span class="xp-titlebar__title"><i class="i">&#xea60;</i> Community — <%= community.name %></span>
        <div class="xp-titlebar__buttons">
          <button class="xp-titlebar__btn xp-titlebar__btn--close" data-close-to="/communities">✕</button>
        </div>
      </div>
      <div class="xp-window__body" style="background: #fff;">
        
        <!-- Community Banner Details -->
        <div class="profile-header">
          <img src="<%= community.avatar_url %>" alt="" class="profile-avatar" style="border-radius: 4px;">
          <div class="profile-info">
            <h1><%= community.name %></h1>
            <div class="profile-stats">
              <span>Category: <strong><%= community.category %></strong></span>
              <span>Members: <strong><%= memberCount %></strong></span>
              <span>Created: <strong><%= formatDate(community.created_at, 'date') %></strong></span>
            </div>
            <p style="font-size: 13px; color: #333; margin: 8px 0;"><%= community.description %></p>

            <div class="profile-actions" style="margin-top: 12px;">
              <% if (currentUser) { %>
                <% if (currentUser.id === community.owner_id) { %>
                  <button class="xp-btn xp-btn--primary" onclick="document.getElementById('community-edit-panel').style.display='block'; document.getElementById('community-avatar-panel').style.display='none'"><i class="i">&#xe3c9;</i> Edit Details</button>
                  <button class="xp-btn xp-btn--primary" onclick="document.getElementById('community-avatar-panel').style.display='block'; document.getElementById('community-edit-panel').style.display='none'"><i class="i">&#xe3b0;</i> Change Avatar</button>
                <% } %>
                <% if (isMember) { %>
                  <span class="xp-btn xp-btn--green" style="cursor: default;"><i class="i">&#xe5cc;</i> Joined</span>
                  <% if (currentUser.id !== community.owner_id) { %>
                    <form method="POST" action="/communities/<%= community.id %>/leave" style="display:inline;">
                      <button type="submit" class="xp-btn xp-btn--danger" data-confirm="Are you sure you want to leave this community?"><i class="i">&#xe725;</i> Leave Group</button>
                    </form>
                  <% } %>
                <% } else { %>
                  <form method="POST" action="/communities/<%= community.id %>/join" style="display:inline;">
                    <button type="submit" class="xp-btn xp-btn--primary"><i class="i">&#xe726;</i> Join Community</button>
                  </form>
                <% } %>
              <% } %>
              <a href="/communities" class="xp-btn"><i class="i">&#xe3ac;</i> Back to Communities</a>
            </div>

            <!-- Community Details Edit Panel (Hidden by default) -->
            <% if (currentUser && currentUser.id === community.owner_id) { %>
              <div id="community-edit-panel" class="xp-fieldset" style="display:none; margin-top: 15px; border-color: #3A6EA5; background:#F0F4F9;">
                <legend><i class="i">&#xe3c9;</i> Edit Community Details</legend>
                <form method="POST" action="/communities/<%= community.id %>/edit">
                  <div class="form-group mb-sm">
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:2px;">Community Name:</label>
                    <input type="text" name="name" class="xp-input w-100" value="<%= community.name %>" required maxlength="100">
                  </div>
                  <div class="form-group mb-sm">
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:2px;">Category:</label>
                    <select name="category" class="xp-select w-100">
                      <% ['General', 'Music', 'MusicZone', 'Movies', 'Technology', 'School Life', 'Nostalgia', 'Fun & Games'].forEach(cat => { %>
                        <option value="<%= cat %>" <%= community.category === cat ? 'selected' : '' %>><%= cat %></option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="form-group mb-sm">
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:2px;">Description:</label>
                    <textarea name="description" class="xp-textarea w-100" rows="3" required><%= community.description %></textarea>
                  </div>
                  <button type="submit" class="xp-btn xp-btn--primary">Save Changes</button>
                  <button type="button" class="xp-btn" onclick="document.getElementById('community-edit-panel').style.display='none'">Cancel</button>
                </form>
              </div>
            <% } %>

            <!-- Community Avatar Picker Panel (Hidden by default) -->
            <% if (currentUser && currentUser.id === community.owner_id) { %>
              <div id="community-avatar-panel" class="xp-fieldset" style="display:none; margin-top: 15px; border-color: #3A6EA5; background:#F0F4F9;">
                <legend><i class="i">&#xe3b0;</i> Select Community Avatar</legend>
                <form method="POST" action="/communities/<%= community.id %>/avatar" enctype="multipart/form-data">
                  <div class="d-flex gap-md" style="flex-wrap:wrap; padding:10px; background:#fff; border:2px inset #999; border-radius:4px; max-height:220px; overflow-y:auto; margin-bottom:10px;">
                    <% 
                      const comPresets = [
                        { path: '/images/avatars/comm_dialup_1783822929238.png', label: 'Dial-Up' },
                        { path: '/images/avatars/comm_games_1783822956740.png', label: 'Games' },
                        { path: '/images/avatars/comm_music_1783822902926.png', label: 'Music' },
                        { path: '/images/avatars/comm_nokia_1783822940940.png', label: 'Nokia' },
                        { path: '/images/avatars/comm_school_1783822917080.png', label: 'School' },
                        { path: '/images/avatars/pixel_computer_1783822705542.png', label: 'Classic PC' },
                        { path: '/images/avatars/crt_monitor_1783831864729.png', label: 'Monitor' },
                        { path: '/images/avatars/floppy_disk_1783831878023.png', label: 'Floppy' }
                      ];
                      comPresets.forEach(p => { 
                    %>
                      <label style="display:flex; flex-direction:column; align-items:center; cursor:pointer; gap:4px; font-size:11px;">
                        <img src="<%= p.path %>" alt="" style="width:50px; height:50px; border:2px outset #ccc; padding:2px; background:#fff; <%= community.avatar_url === p.path ? 'border-color:#3A6EA5; box-shadow:0 0 4px #3A6EA5;' : '' %>">
                        <span style="font-weight:<%= community.avatar_url === p.path ? 'bold' : 'normal' %>;"><%= p.label %></span>
                        <input type="radio" name="avatar_url" value="<%= p.path %>" <%= community.avatar_url === p.path ? 'checked' : '' %> style="margin-top:2px;">
                      </label>
                    <% }) %>
                  </div>
                  <div style="margin-bottom:12px; padding:8px; background:#fff; border:1px solid #ccc;">
                    <label style="font-size:11px; font-weight:bold; display:block; margin-bottom:4px;">Or Upload a Custom Logo:</label>
                    <input type="file" name="custom_community_avatar" accept="image/*" class="xp-input" style="font-size:11px; padding:2px;">
                  </div>
                  <button type="submit" class="xp-btn xp-btn--primary">Save Avatar</button>
                  <button type="button" class="xp-btn" onclick="document.getElementById('community-avatar-panel').style.display='none'">Cancel</button>
                </form>
              </div>
            <% } %>
          </div>
        </div>

        <div class="layout-two-col">
          <!-- Left: Discussion Forum -->
          <div class="layout-two-col__main">
            
            <!-- MusicZone Song Player -->
            <% if (community.category === 'MusicZone') { %>
              <% 
                const displayUrl = community.song_url || (stations.find(s => {
                  const cleanName = community.name.replace('Zone', '').trim().toLowerCase();
                  return s.name.toLowerCase().includes(cleanName) || cleanName.includes(s.name.toLowerCase());
                }) || {}).url;
              %>
              
              <div class="winamp-player mb-md" style="width:100%; background:#2c2c2c; border:3px outset #555; padding:12px; border-radius:4px; font-family:'Courier New', monospace; color:#00ff00; box-shadow:0 4px 10px rgba(0,0,0,0.3); box-sizing:border-box;">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #444; padding-bottom:6px; margin-bottom:8px; font-size:11px; color:#aaa; font-family:var(--font-system);">
                  <span>📻 WINAMP 2.80 - RETRO PLAYER</span>
                  <span style="color:#00ff00; font-weight:bold;">128KBPS / 44.1KHZ</span>
                </div>
                
                <div style="display:flex; gap:12px; align-items:center; background:#111; padding:10px; border:2px inset #444; border-radius:3px;">
                  <!-- Bouncing Visualizer Bars (Retro Winamp Style!) -->
                  <div class="winamp-vis" style="display:flex; align-items:flex-end; gap:2px; height:40px; width:60px; background:#000; border:1px solid #333; padding:2px;">
                    <div style="flex:1; background:#00ff00; height:80%; animation: bounce-vis 1.2s ease infinite alternate;"></div>
                    <div style="flex:1; background:#00ff00; height:40%; animation: bounce-vis 0.8s ease infinite alternate 0.2s;"></div>
                    <div style="flex:1; background:#00ff00; height:95%; animation: bounce-vis 1.5s ease infinite alternate 0.1s;"></div>
                    <div style="flex:1; background:#00ff00; height:60%; animation: bounce-vis 1.0s ease infinite alternate 0.3s;"></div>
                    <div style="flex:1; background:#00ff00; height:30%; animation: bounce-vis 0.7s ease infinite alternate 0.4s;"></div>
                    <div style="flex:1; background:#00ff00; height:75%; animation: bounce-vis 1.3s ease infinite alternate 0.2s;"></div>
                  </div>
                  
                  <div style="flex:1; min-width:0;">
                    <div class="winamp-title-marquee" style="font-weight:bold; font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= community.name %></div>
                    <div style="font-size:10px; color:#888; font-family:var(--font-system); margin-top:2px;">Playing active stream from web...</div>
                  </div>
                </div>

                <% if (displayUrl) { %>
                  <audio src="<%= displayUrl %>" id="winamp-audio-element" style="display:none;"></audio>
                  
                  <!-- Winamp Skeuomorphic Control Bar -->
                  <div style="display:flex; align-items:center; justify-content:center; gap:8px; margin-top:10px; font-family:var(--font-system);">
                    <button class="xp-btn" id="winamp-play-btn" onclick="toggleWinampPlay()" style="min-width:60px; font-weight:bold; background: linear-gradient(180deg, #5c5c5c 0%, #3a3a3a 100%); color:#fff; border-color:#222;"><i class="i">&#xe037;</i> PLAY</button>
                    <button class="xp-btn" id="winamp-pause-btn" onclick="toggleWinampPause()" style="min-width:60px; display:none; font-weight:bold; background: linear-gradient(180deg, #5c5c5c 0%, #3a3a3a 100%); color:#fff; border-color:#222;"><i class="i">&#xe034;</i> PAUSE</button>
                    <button class="xp-btn" onclick="stopWinamp()" style="min-width:60px; font-weight:bold; background: linear-gradient(180deg, #5c5c5c 0%, #3a3a3a 100%); color:#fff; border-color:#222;"><i class="i">&#xe047;</i> STOP</button>
                    
                    <!-- Volume slider track -->
                    <div style="display:flex; align-items:center; gap:4px; margin-left:auto; font-size:11px; color:#aaa;">
                      <span>VOL:</span>
                      <input type="range" min="0" max="1" step="0.1" value="0.8" oninput="changeWinampVolume(this.value)" style="width:60px; height:4px; background:#444; outline:none; border:none; cursor:pointer;">
                    </div>
                  </div>

                  <!-- Visualizer animation keyframes -->
                  <style>
                    @keyframes bounce-vis {
                      0% { height: 10%; }
                      100% { height: 100%; }
                    }
                  </style>
                  
                  <script>
                    const winampAudio = document.getElementById('winamp-audio-element');
                    const winampPlayBtn = document.getElementById('winamp-play-btn');
                    const winampPauseBtn = document.getElementById('winamp-pause-btn');

                    function toggleWinampPlay() {
                      if (winampAudio) {
                        winampAudio.play();
                        winampPlayBtn.style.display = 'none';
                        winampPauseBtn.style.display = 'inline-block';
                      }
                    }

                    function toggleWinampPause() {
                      if (winampAudio) {
                        winampAudio.pause();
                        winampPlayBtn.style.display = 'inline-block';
                        winampPauseBtn.style.display = 'none';
                      }
                    }

                    function stopWinamp() {
                      if (winampAudio) {
                        winampAudio.pause();
                        winampAudio.currentTime = 0;
                        winampPlayBtn.style.display = 'inline-block';
                        winampPauseBtn.style.display = 'none';
                      }
                    }

                    function changeWinampVolume(val) {
                      if (winampAudio) {
                        winampAudio.volume = val;
                      }
                    }
                  </script>
                <% } else { %>
                  <div style="text-align:center; padding:12px; color:#ff3333; font-size:12px; font-weight:bold; font-family:var(--font-system);">
                     ⚠️ No song uploaded to this Zone yet.
                  </div>
                <% } %>

                <!-- Owner Upload Song Form widget -->
                <% if (currentUser && currentUser.id === community.owner_id) { %>
                  <div style="border-top:1px solid #444; padding-top:10px; margin-top:10px; font-family:var(--font-system);">
                    <form method="POST" action="/communities/<%= community.id %>/upload-song" enctype="multipart/form-data" style="display:flex; align-items:center; justify-content:space-between; gap:10px;">
                      <label style="font-size:11px; color:#aaa; font-weight:bold;">📤 Change Song:</label>
                      <input type="file" name="song_file" accept="audio/*" required style="font-size:10px; color:#ccc; max-width:180px;">
                      <button type="submit" class="xp-btn xp-btn--primary" style="font-size:11px; padding:2px 8px;">Upload</button>
                    </form>
                  </div>
                <% } %>
              </div>
            <% } %>
            
            <!-- Create a New Topic Form -->
            <% if (currentUser && isMember) { %>
              <div class="xp-fieldset">
                <legend><i class="i">&#xe71f;</i> Post a New Topic</legend>
                <form method="POST" action="/communities/<%= community.id %>/post">
                  <div class="form-group mb-sm">
                    <input type="text" name="title" class="xp-input w-100" placeholder="Topic Title..." required>
                  </div>
                  <div class="form-group mb-sm">
                    <textarea name="content" class="xp-textarea w-100" rows="3" placeholder="Write something to discuss..." required></textarea>
                  </div>
                  <button type="submit" class="xp-btn xp-btn--primary">Post Topic</button>
                </form>
              </div>
            <% } else if (currentUser && !isMember) { %>
              <div class="outset-panel text-center text-small text-muted" style="padding: 10px; border-color: #ED1A7B;">
                <i class="i">&#xe530;</i> You must join this community to start or reply to topics.
              </div>
            <% } %>

            <!-- Forum Topics list -->
            <div class="xp-fieldset">
              <legend><i class="i">&#xe54d;</i> Discussion Forum</legend>
              <% if (posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                  <div class="post-item" style="border-bottom: 2px solid #f0ccd7; padding-bottom: 12px; margin-bottom: 12px;">
                    <div style="display: flex; gap: 10px; align-items: flex-start;">
                      <img src="<%= post.author_avatar %>" alt="" style="width: 32px; height: 32px; border-radius: 4px;">
                      <div>
                        <a href="/communities/<%= community.id %>/post/<%= post.id %>" class="post-item__title" style="color: #ED1A7B; font-weight: bold; font-size: 14px; text-decoration: none;">
                          <%= post.title || 'Untitled Post' %>
                        </a>
                        <div class="post-item__meta" style="font-size: 11px; color: #666; margin-top: 2px;">
                          Posted by <a href="/profile/<%= post.author_username %>"><%= post.author_display_name %></a> 
                          on <%= formatDate(post.created_at) %>
                        </div>
                        <div class="post-item__content" style="margin-top: 8px; font-size: 13px; line-height: 1.4; color: #333; word-break: break-word;">
                          <%= post.content %>
                        </div>
                        <div class="mt-sm">
                          <a href="/communities/<%= community.id %>/post/<%= post.id %>" style="font-size: 12px; font-weight: bold; color: #4A7EBB;">
                            <i class="i">&#xe54d;</i> View discussion / replies →
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-muted text-small text-center" style="padding: 20px;">No topics discussed yet. Be the first to start a conversation!</p>
              <% } %>
            </div>

          </div>

          <!-- Right: Members Sidebar -->
          <div class="layout-two-col__sidebar" style="width: 240px;">
            <div class="outset-panel">
              <div class="section-header"><i class="i">&#xea60;</i> Members (<%= memberCount %>)</div>
              
              <div class="top8-grid" style="grid-template-columns: repeat(2, 1fr); gap: 6px; padding: 4px;">
                <% members.forEach(member => { %>
                  <div class="top8-card" style="padding: 4px; background: #fff; border-color: #C0C0C0;">
                    <img src="<%= member.avatar_url %>" alt="" style="width: 40px; height: 40px; border-radius: 4px;">
                    <a href="/profile/<%= member.username %>" style="font-size: 10px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      <%= member.display_name %>
                    </a>
                    <span class="text-muted" style="font-size: 9px; display: block;"><%= member.role %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%- include('partials/taskbar') %>
  <script src="/js/app.js"></script>
</body>
</html>
